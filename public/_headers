# Always revalidate the entry document and service-worker metadata so a new
# Cloudflare deployment is picked up immediately instead of from a stale cache.
/
  Cache-Control: no-cache, no-store, must-revalidate
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
/registerSW.js
  Cache-Control: no-cache, no-store, must-revalidate
/manifest.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate

# Hashed build assets are content-addressed and safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
