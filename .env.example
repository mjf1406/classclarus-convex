# Copy to .env and adjust as needed:
#   cp .env.example .env
#   # set INSTANCE_SECRET (required) — generate with: openssl rand -hex 32
#   docker compose up -d --build

# --- Required: Convex instance identity (admin keys derive from these) ---
INSTANCE_NAME=convex-self-hosted
# REQUIRED: 64-char hex. Example only — replace before any real use:
INSTANCE_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Browser-reachable URLs (defaults work for local docker compose) ---
PORT=3210
SITE_PROXY_PORT=3211
DASHBOARD_PORT=6791
WEB_PORT=3000

CONVEX_CLOUD_ORIGIN=http://127.0.0.1:3210
# JWT issuer / OpenID discovery base. The backend fetches this URL from INSIDE
# the container during auth. Keep loopback (127.0.0.1) for Docker Compose —
# a LAN IP here fails under Docker hairpin NAT even when browsers can open it.
# For LAN clients, set VITE_CONVEX_URL / CONVEX_CLOUD_ORIGIN / SITE_URL to the
# host IP; leave CONVEX_SITE_ORIGIN as loopback unless you use a real reverse-
# proxied hostname for Google OAuth or file-storage URLs on port 3211.
CONVEX_SITE_ORIGIN=http://127.0.0.1:3211
NEXT_PUBLIC_DEPLOYMENT_URL=http://127.0.0.1:3210
# Baked into the SPA at image build time — rebuild web if you change this
VITE_CONVEX_URL=http://127.0.0.1:3210

# Frontend origin used for OAuth redirects / post-login returns
SITE_URL=http://localhost:3000

# Pin Convex backend/dashboard images (git SHA tag from ghcr.io/get-convex/*)
CONVEX_IMAGE_TAG=abdd9b30f89c0e7c18c4213b99cd10e4bad33f8c

# --- Self-host auth mode ---
# When true: email/password registration + sign-in (replaces Google on this deployment).
# Also baked into the SPA as VITE_AUTH_PASSWORD_ENABLED — rebuild `web` after changing.
# Production / Convex Cloud should leave this unset or false (Google-only).
AUTH_PASSWORD_ENABLED=false

# JWT issuer for convex/auth.config.ts is process.env.CONVEX_SITE_URL, which the
# self-hosted backend exposes automatically from CONVEX_SITE_ORIGIN above.
# Do not set CONVEX_SITE_URL via `convex env set` — it is a reserved system variable.

# --- Optional: Google OAuth (Convex Auth) — ignored when AUTH_PASSWORD_ENABLED=true ---
# Callback URL to register in Google Cloud Console:
#   ${CONVEX_SITE_ORIGIN}/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# --- Optional: Convex Auth JWT keys ---
# Leave blank to auto-generate on first boot (saved in the Docker "bootstrap" volume).
# Or generate locally: bun run scripts/generate-auth-keys.mjs
# JWT_PRIVATE_KEY=
# JWKS=
